{
  "name": "frameworks-core",
  "version": "0.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "packageManager": "npm@12.0.1",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=12.0.0"
    }
  },
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prettier": "prettier -c .",
    "prettier:fix": "prettier -w .",
    "test": "npm run test:unit -w @serverlessinc/sf-core -w @serverless/framework",
    "setup-dev-mode": "bash setup-dev-for-dev-mode.sh",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/*",
    "!packages/framework-dist",
    "!packages/sf-core-installer",
    "release-scripts"
  ],
  "author": "Serverless Inc.",
  "devDependencies": {
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx}": [
      "prettier -w"
    ]
  },
  "overrides": {
    "help-me": "^5.0.0",
    "fast-xml-parser": "^5.3.6",
    "aws-sdk": {
      "uuid": "^11.1.1"
    }
  },
  "allowScripts": {
    "aws-crt": true,
    "aws-sdk": true,
    "cpu-features": true,
    "es5-ext": true,
    "esbuild": true,
    "fsevents": true,
    "protobufjs": true,
    "ssh2": true,
    "unrs-resolver": true
  }
}
